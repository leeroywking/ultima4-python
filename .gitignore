# Machine-specific build artifacts (./run rebuilds the venv on first use)
u4py/.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.claude/settings.local.json

# Unrelated projects that happen to share this directory (not part of the U4 rewrite)
/bass/
/quake3/

# Decompiled DOS source — a nested git repo; reference only, not needed to run/play.
/u4/

# Runtime saves the player writes with Quit&Save (Journey Onward reloads them). The
# committed seed is the editable data/party_start.json, never a binary .SAV.
u4py/data/*.SAV
u4py/data/*.sav

# Render outputs written into u4py/ root by ./run smoke / render_view / debug boots (the real
# art lives in u4py/assets/ and u4py/docs/tiles/, which are NOT matched by this root-only glob).
u4py/*.png
